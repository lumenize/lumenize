{
  "name": "testing-plain-do",
  "main": "./test-harness.ts",  // The only change from your real wrangler.jsonc
  "compatibility_date": "2026-03-12",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "migrations": [
    {
      "new_sqlite_classes": [
        "MyDO"
      ],
      "tag": "v1"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyDO",
        "name": "MY_DO"
      }
    ]
  }
}