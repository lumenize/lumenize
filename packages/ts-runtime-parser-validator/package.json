{
  "name": "@lumenize/ts-runtime-parser-validator",
  "version": "0.23.0",
  "description": "Parse, don't validate — typia-powered runtime parser/validator for Cloudflare Workers (experimental)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:coverage": "vitest --coverage --run",
    "coverage": "COVERAGE=true vitest --run --coverage",
    "types": "wrangler types",
    "bundle": "node scripts/bundle-dependencies.mjs"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "typia",
    "validation",
    "parse",
    "runtime-type-checking"
  ],
  "author": "Lumenize",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@vitest/coverage-istanbul": "4.1.4",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.2",
    "vitest": "4.1.4",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@typia/transform": "12.0.2"
  },
  "peerDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "vitest": "4.1.4"
  }
}
