{
  "name": "@lumenize/ts-runtime-parser-validator",
  "version": "0.24.0",
  "description": "TypeScript runtime validator/parser for Cloudflare Workers — dynamic schemas, DO facets, typia-powered (parse, don't validate). Experimental.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:coverage": "vitest --coverage --run",
    "coverage": "COVERAGE=true vitest --run --coverage",
    "types": "wrangler types",
    "bundle": "node scripts/bundle-dependencies.mjs"
  },
  "keywords": [
    "cloudflare",
    "cloudflare-workers",
    "workers",
    "durable-objects",
    "do-facets",
    "dynamic-worker",
    "dynamic-worker-loader",
    "dwl",
    "worker-loader",
    "typescript",
    "schema",
    "dynamic-schema",
    "typescript-as-schema",
    "validator",
    "validation",
    "parser",
    "parse",
    "parse-dont-validate",
    "typia",
    "zod",
    "ajv",
    "runtime",
    "runtime-type-checking"
  ],
  "author": "Lumenize",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@vitest/coverage-istanbul": "4.1.4",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.2",
    "typia": "^12.0.2",
    "vitest": "4.1.4",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@typia/transform": "*"
  },
  "peerDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "vitest": "4.1.4"
  }
}
