{
  "name": "@lumenize/mesh",
  "version": "0.26.0",
  "description": "Lumenize Mesh - communication framework for Cloudflare Durable Objects",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client-index.ts"
  },
  "imports": {
    "#lmz-api-context": {
      "types": "./src/lmz-api-context.workerd.ts",
      "workerd": "./src/lmz-api-context.workerd.ts",
      "worker": "./src/lmz-api-context.workerd.ts",
      "node": "./src/lmz-api-context.workerd.ts",
      "browser": "./src/lmz-api-context.browser.ts",
      "default": "./src/lmz-api-context.workerd.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "test": "vitest --run && npm run test:node-import",
    "test:coverage": "vitest --coverage --run",
    "test:node-import": "tsx --test test/node-import.test.mjs",
    "coverage": "COVERAGE=true vitest --run --coverage",
    "types": "wrangler types"
  },
  "keywords": [
    "cloudflare",
    "durable-objects",
    "workers",
    "mesh",
    "rpc",
    "lumenize"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lumenize/auth": "^0.26.0",
    "@lumenize/debug": "^0.26.0",
    "@lumenize/routing": "^0.26.0",
    "@lumenize/structured-clone": "^0.26.0",
    "cron-schedule": "^6.0.0",
    "ulid-workers": "^2.1.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@lumenize/debug": "*",
    "@lumenize/testing": "^0.26.0",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-istanbul": "4.1.4",
    "http-proxy": "^1.18.1",
    "playwright": "^1.48.2",
    "tsx": "^4.19.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "4.1.4",
    "wrangler": "^4.86.0"
  },
  "peerDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "vitest": "4.1.4"
  },
  "gitHead": "59bf07ef73368b771a8fe9446bd8aa91ba96fd5c"
}
