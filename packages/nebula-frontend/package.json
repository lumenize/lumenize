{
  "name": "@lumenize/nebula-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Vue 3 reactive factory for NebulaClient — createNebulaClient() wraps a NebulaClient in a path-aware reactive store with optimistic writes, debounced transactions, conflict resolution, and auto-subscribe. UNLICENSED until Nebula ships externally.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "vitest --run --project unit --project e2e --project browser",
    "test:unit": "vitest --run --project unit",
    "test:e2e": "vitest --run --project e2e",
    "test:browser": "vitest --run --project browser",
    "coverage": "COVERAGE=true vitest --run --coverage --project unit --project e2e",
    "types": "wrangler types"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "nebula",
    "vue",
    "reactivity"
  ],
  "author": "Lumenize",
  "license": "UNLICENSED",
  "dependencies": {
    "@vue/reactivity": "^3.5.13",
    "@vue/runtime-core": "^3.5.13",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@lumenize/testing": "*",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-istanbul": "4.1.4",
    "@types/jsdom": "^21.1.7",
    "jsdom": "^25.0.1",
    "playwright": "^1.48.2",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "4.1.4",
    "wrangler": "^4.86.0"
  }
}
