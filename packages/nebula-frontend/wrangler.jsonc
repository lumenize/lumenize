{
  // Package-root config — present so `wrangler types` generates the base global
  // `Env` and the postinstall symlink script links `.dev.vars` +
  // `cloudflare-test-env.d.ts` here. This package is a client library, not a
  // deployed Worker; the e2e test harness has its own wrangler at
  // test/e2e/wrangler.jsonc with the full Nebula DO bindings.
  "name": "lumenize-nebula-frontend",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-12"
}
