{
  "name": "nebula-auth",
  "main": "test-worker-and-dos.ts",
  "compatibility_date": "2026-03-12",
  "durable_objects": {
    "bindings": [
      {
        "name": "NEBULA_AUTH",
        "class_name": "NebulaAuth"
      },
      {
        "name": "NEBULA_AUTH_REGISTRY",
        "class_name": "NebulaAuthRegistry"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "NebulaAuth",
        "NebulaAuthRegistry"
      ]
    }
  ],
  "services": [
    {
      "binding": "AUTH_EMAIL_SENDER",
      "service": "nebula-auth",
      "entrypoint": "NebulaEmailSender"
    }
  ],
  "ratelimits": [
    {
      "name": "NEBULA_AUTH_RATE_LIMITER",
      "namespace_id": "2001",
      "simple": {
        "limit": 100,
        "period": 60
      }
    }
  ],
  "vars": {
    "PRIMARY_JWT_KEY": "BLUE",
    "NEBULA_AUTH_REDIRECT": "/app"
  }
}
