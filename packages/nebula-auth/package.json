{
  "name": "@lumenize/nebula-auth",
  "version": "0.24.0",
  "private": true,
  "description": "Multi-tenant authentication for Nebula — magic link login, JWT access tokens, admin roles scoped to Universe > Galaxy > Star",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:coverage": "vitest --coverage --run",
    "coverage": "COVERAGE=true vitest --run --coverage",
    "types": "cd test && wrangler types"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "authentication",
    "jwt",
    "magic-link",
    "multi-tenant",
    "nebula"
  ],
  "author": "Lumenize",
  "license": "UNLICENSED",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@lumenize/testing": "*",
    "@vitest/coverage-istanbul": "4.1.4",
    "typescript": "^5.9.2",
    "vitest": "4.1.4",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@lumenize/auth": "*",
    "@lumenize/debug": "*",
    "@lumenize/routing": "*",
    "@lumenize/sql-migrations": "*"
  },
  "peerDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "vitest": "4.1.4"
  }
}
