# Prevent stale compiled TypeScript files in test directories
# These cause vitest to load old .js files instead of current .ts source
# This is critical for Worker packages that run TypeScript directly during development
**/test/**/*.js
**/test/**/*.js.map
**/test/**/*.d.ts
**/test/**/*.d.ts.map

# ...but DO track hand-written .d.ts test FIXTURES (source, not compiled output).
# The rules above target generated/compiled .d.ts (worker-configuration.d.ts,
# stale tsc output); these schema fixtures are `?raw`-imported by for-docs tests
# and must ship, or the test fails in CI with ENOENT on './schema.d.ts'.
!**/test/**/schema.d.ts

# Coverage output
**/coverage/

# Worker configuration (auto-generated by wrangler types)
**/worker-configuration.d.ts
