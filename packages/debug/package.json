{
  "name": "@lumenize/debug",
  "version": "0.25.0",
  "description": "Zero-dependency debug logging for Cloudflare Workers, Node.js, Bun, and browsers",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "workerd": "./src/index.workerd.ts",
      "worker": "./src/index.workerd.ts",
      "node": "./src/index.node.ts",
      "browser": "./src/index.browser.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "vitest --run",
    "coverage": "vitest --run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "4.1.4",
    "vitest": "4.1.4"
  },
  "keywords": [
    "debug",
    "logging",
    "cloudflare-workers",
    "durable-objects",
    "nodejs",
    "browser"
  ],
  "author": "Larry Maccherone",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
