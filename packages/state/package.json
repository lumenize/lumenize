{
  "name": "@lumenize/state",
  "version": "0.26.0",
  "description": "Path-based reactive store for Lumenize — getState/setState/subscribe with hierarchical notification, middleware, and computed derivations. Works in Cloudflare Workers, Node.js, Bun, and browsers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "vitest --run",
    "coverage": "vitest --run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lumenize/debug": "^0.26.0"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "4.1.4",
    "vitest": "4.1.4"
  },
  "keywords": [
    "state",
    "reactive",
    "store",
    "path-based",
    "lumenize"
  ],
  "author": "Larry Maccherone",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
