{
  "name": "@lumenize/sql-migrations",
  "version": "0.26.0",
  "description": "Minimal id-gated SQL schema migrations for SQLite-backed Cloudflare Durable Objects — synchronous, atomic, run-once",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest --run",
    "coverage": "vitest --run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@cloudflare/workers-types": "^4.20250110.0",
    "@vitest/coverage-istanbul": "4.1.4",
    "typescript": "^5.9.2",
    "vitest": "4.1.4",
    "wrangler": "^4.86.0"
  },
  "keywords": [
    "durable-objects",
    "sqlite",
    "migrations",
    "schema-migrations",
    "cloudflare-workers"
  ],
  "author": "Larry Maccherone",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
