{
  "name": "auth-e2e-email-resend-test",
  "main": "./test-harness.ts",
  "compatibility_date": "2026-03-12",
  "durable_objects": {
    "bindings": [
      {
        "name": "LUMENIZE_AUTH",
        "class_name": "LumenizeAuth"
      }
    ]
  },
  "services": [
    {
      "binding": "AUTH_EMAIL_SENDER",
      "service": "auth-e2e-email-resend-test",
      "entrypoint": "AuthEmailSender"
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["LumenizeAuth"]
    }
  ],
  "ratelimits": [
    {
      "name": "LUMENIZE_AUTH_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 100,
        "period": 60
      }
    }
  ],
  "vars": {
    "PRIMARY_JWT_KEY": "BLUE",
    "LUMENIZE_AUTH_REDIRECT": "/app",
    // No EMAIL binding here — select Resend explicitly (tasks/lumenize-email.md
    // Phase 3) rather than relying on createEmailTransport's warn-fallback.
    "EMAIL_PROVIDER": "resend"
  }
}
