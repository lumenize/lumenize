{
  "name": "auth-hono-test",
  "main": "./test-harness.ts",
  "compatibility_date": "2026-03-12",
  "durable_objects": {
    "bindings": [
      {
        "name": "LUMENIZE_AUTH",
        "class_name": "LumenizeAuth"
      },
      {
        "name": "ECHO_DO",
        "class_name": "EchoDO"
      }
    ]
  },
  // Self-referencing service binding: AuthEmailSender is a WorkerEntrypoint
  // exported from this same Worker (test-harness.ts)
  "services": [
    {
      "binding": "AUTH_EMAIL_SENDER",
      "service": "auth-hono-test",
      "entrypoint": "AuthEmailSender"
    }
  ],
  // Cloudflare Email Sending binding (env.EMAIL.send), used by the Cloudflare email transport.
  // `remote: true` proxies to the real Cloudflare Email Sending service during
  // local dev / vitest so tests exercise the full end-to-end path.
  "send_email": [
    {
      "name": "EMAIL",
      "remote": true
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["LumenizeAuth"]
    },
    {
      "tag": "v2",
      "new_classes": ["EchoDO"]
    }
  ],
  "ratelimits": [
    {
      "name": "LUMENIZE_AUTH_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 100,
        "period": 60
      }
    }
  ],
  "vars": {
    "PRIMARY_JWT_KEY": "BLUE",
    "LUMENIZE_AUTH_REDIRECT": "/app"
  }
}
