{
  "name": "@lumenize/auth",
  "version": "0.24.0",
  "description": "De✨light✨ful authentication for Cloudflare Durable Objects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:coverage": "vitest --coverage --run",
    "coverage": "COVERAGE=true vitest --run --coverage",
    "types": "wrangler types"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "authentication",
    "jwt",
    "magic-link"
  ],
  "author": "Lumenize",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@lumenize/testing": "^0.25.0",
    "@vitest/coverage-istanbul": "4.1.4",
    "hono": "^4.11.9",
    "typescript": "^5.9.2",
    "vitest": "4.1.4",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@lumenize/debug": "^0.25.0",
    "@lumenize/routing": "^0.25.0"
  },
  "peerDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "vitest": "4.1.4"
  }
}
