{
  "name": "nebula-test",
  "main": "test-worker-and-dos.ts",
  "compatibility_date": "2025-09-12",
  "durable_objects": {
    "bindings": [
      { "name": "NEBULA_CLIENT_GATEWAY", "class_name": "NebulaClientGateway" },
      { "name": "UNIVERSE", "class_name": "Universe" },
      { "name": "GALAXY", "class_name": "Galaxy" },
      { "name": "STAR", "class_name": "StarTest" },
      { "name": "RESOURCE_HISTORY", "class_name": "ResourceHistory" },
      { "name": "NEBULA_AUTH", "class_name": "NebulaAuth" },
      { "name": "NEBULA_AUTH_REGISTRY", "class_name": "NebulaAuthRegistry" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "NebulaClientGateway",
        "Universe",
        "Galaxy",
        "StarTest",
        "ResourceHistory",
        "NebulaAuth",
        "NebulaAuthRegistry"
      ]
    }
  ],
  "services": [
    {
      "binding": "AUTH_EMAIL_SENDER",
      "service": "nebula-test",
      "entrypoint": "NebulaEmailSender"
    }
  ],
  "ratelimits": [
    {
      "name": "NEBULA_AUTH_RATE_LIMITER",
      "namespace_id": "3001",
      "simple": {
        "limit": 100,
        "period": 60
      }
    }
  ],
  "vars": {
    "PRIMARY_JWT_KEY": "BLUE",
    "NEBULA_AUTH_REDIRECT": "/app"
  }
}
