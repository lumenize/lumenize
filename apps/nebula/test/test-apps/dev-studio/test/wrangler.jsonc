{
  // DevStudio node test (Phase 3.5b). DevStudio (shell Workspace + isomorphic-git)
  // + DevStarOntologyProbe (the .dev apply target) + LOADER (the validator facet).
  // nodejs_compat is REQUIRED: @cloudflare/shell + isomorphic-git touch node:
  // builtins. Run with `npx vitest run --project dev-studio`.
  "name": "nebula-dev-studio-test",
  "main": "../index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "worker_loaders": [{ "binding": "LOADER" }],
  "durable_objects": {
    "bindings": [
      { "name": "DEV_STUDIO", "class_name": "DevStudioLoopProbe" },
      { "name": "STAR", "class_name": "DevStarOntologyProbe" },
      { "name": "GALAXY", "class_name": "Galaxy" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DevStudioLoopProbe", "DevStarOntologyProbe", "Galaxy"]
    }
  ]
}
