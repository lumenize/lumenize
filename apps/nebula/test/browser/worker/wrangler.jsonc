{
  "name": "nebula-browser-test",
  "main": "./index.ts",
  "compatibility_date": "2026-04-01",
  // nodejs_compat (NOT the legacy `nodejs_compat_v2` flag-name): this worker
  // imports the @lumenize/nebula barrel, which transitively pulls DevStar →
  // @vue/compiler-sfc (imports `node:os` etc.) + the vendored tsc bundle. Real
  // `wrangler dev` (this harness) only resolves `node:` builtins under plain
  // `nodejs_compat`; `nodejs_compat_v2` crashes startup with `No such module
  // "node:os"`. Unified with prod + the other test wranglers.
  "compatibility_flags": ["nodejs_compat"],
  "worker_loaders": [{ "binding": "LOADER" }],
  "durable_objects": {
    "bindings": [
      { "name": "NEBULA_CLIENT_GATEWAY", "class_name": "NebulaClientGateway" },
      { "name": "UNIVERSE", "class_name": "Universe" },
      { "name": "GALAXY", "class_name": "Galaxy" },
      { "name": "STAR", "class_name": "StarTest" },
      // DevStar (production class) so the real-chromium harness can compile a
      // fixture SFC (DevStar.compileSFC) and serve the preview (Star.onRequest)
      // same-origin — the self-hosted-assets Phase-1 mount test.
      { "name": "DEV_STAR", "class_name": "DevStar" },
      { "name": "NEBULA_AUTH", "class_name": "NebulaAuth" },
      { "name": "NEBULA_AUTH_REGISTRY", "class_name": "NebulaAuthRegistry" },
      { "name": "BenchAgent", "class_name": "BenchAgent" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "NebulaClientGateway",
        "Universe",
        "Galaxy",
        "StarTest",
        "ResourceHistory",
        "NebulaAuth",
        "NebulaAuthRegistry"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["BenchAgent"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["BenchBroadcaster", "BenchFanoutHelper"]
    },
    {
      "tag": "v4",
      "deleted_classes": ["BenchBroadcaster", "BenchFanoutHelper"]
    },
    {
      "tag": "v5",
      "deleted_classes": ["ResourceHistory"]
    },
    {
      "tag": "v6",
      "new_sqlite_classes": ["DevStar"]
    }
  ],
  "services": [
    {
      "binding": "AUTH_EMAIL_SENDER",
      "service": "nebula-browser-test",
      "entrypoint": "TestNebulaEmailSender"
    },
    {
      "binding": "LUMENIZE_BROADCAST_TIER",
      "service": "nebula-browser-test",
      "entrypoint": "BenchFanoutTier"
    }
  ],
  // Cloudflare Email Sending binding used by CloudflareEmailSender (which
  // NebulaEmailSender extends, after the migration on main). `remote: true`
  // proxies to the real Cloudflare Email Sending service so the test
  // exercises the full email round-trip via the deployed email-test Worker.
  "send_email": [
    {
      "name": "EMAIL",
      "remote": true
    }
  ],
  "ratelimits": [
    {
      "name": "NEBULA_AUTH_RATE_LIMITER",
      "namespace_id": "3001",
      "simple": {
        "limit": 100,
        "period": 60
      }
    }
  ],
  "vars": {
    "PRIMARY_JWT_KEY": "BLUE",
    "NEBULA_AUTH_REDIRECT": "/app",
    // Allow Playwright + Vite dev/preview origins so the browser test page can
    // call this deployed-via-miniflare worker cross-origin. Empty in production
    // (single-origin deploy); per-test config provides whatever origins the
    // test runner serves the page from.
    "LUMENIZE_APPROVED_ORIGINS": "http://localhost:5173,http://localhost:4173",
    // Fanout-scaling bench overrides for Star.#broadcast. Comment out / unset
    // both when not actively running an experiment to restore production
    // behavior (svc.broadcast default threshold=100, onResult handler wired).
    // "STAR_BROADCAST_DIRECT_THRESHOLD": "Infinity",
    // "STAR_BROADCAST_OMIT_ON_RESULT": "1"
  }
}
