{
  "name": "@lumenize/nebula",
  "version": "0.24.0",
  "private": true,
  "description": "Nebula application — multi-tenant Durable Objects with universe/galaxy/star hierarchy",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./client": {
      "import": "./src/client-index.ts",
      "types": "./src/client-index.ts"
    },
    "./frontend": {
      "import": "./src/frontend-index.ts",
      "types": "./src/frontend-index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "test": "vitest --run --project unit --project frontend --project baseline --project container --project dev-studio --project browser",
    "test:coverage": "vitest --coverage --run --project unit --project frontend --project baseline --project container --project dev-studio --project browser",
    "coverage": "COVERAGE=true vitest --run --coverage --project unit --project frontend --project baseline --project container --project dev-studio --project browser",
    "bench": "vitest --run --project browser-bench transactions",
    "bench:throughput": "vitest --run --project browser-bench throughput.benchmark",
    "bench:multi": "vitest --run --project browser-bench throughput-multi",
    "bench:fanout": "vitest --run --project browser-bench fanout.benchmark",
    "bench:fanout:agents": "vitest --run --project browser-bench fanout-agents.benchmark",
    "bench:all": "vitest --run --project browser-bench",
    "types": "wrangler types"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "nebula",
    "multi-tenant"
  ],
  "author": "Lumenize",
  "license": "UNLICENSED",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "@lumenize/testing": "*",
    "@types/jsdom": "^21.1.7",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-istanbul": "4.1.4",
    "agents": "^0.14.2",
    "daisyui": "5.5.23",
    "http-proxy": "^1.18.1",
    "jsdom": "^25.0.1",
    "lucide-vue-next": "1.0.0",
    "playwright": "^1.48.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "4.1.4",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@cloudflare/shell": "^0.4.0",
    "@lumenize/auth": "*",
    "@lumenize/debug": "*",
    "@lumenize/mesh": "*",
    "@lumenize/nebula-auth": "*",
    "@lumenize/routing": "*",
    "@lumenize/structured-clone": "*",
    "@lumenize/ts-runtime-parser-validator": "*",
    "@vue/compiler-sfc": "^3.5.13",
    "isomorphic-git": "^1.38.4",
    "@vue/reactivity": "^3.5.13",
    "@vue/runtime-core": "^3.5.13",
    "typescript": "^5.9.2",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "vitest": "4.1.4"
  }
}
