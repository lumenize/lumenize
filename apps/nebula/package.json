{
  "name": "@lumenize/nebula",
  "version": "0.24.0",
  "private": true,
  "description": "Nebula application — multi-tenant Durable Objects with universe/galaxy/star hierarchy",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:coverage": "vitest --coverage --run",
    "coverage": "COVERAGE=true vitest --run --coverage",
    "bench": "vitest bench --run --project browser-bench",
    "types": "wrangler types"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "nebula",
    "multi-tenant"
  ],
  "author": "Lumenize",
  "license": "UNLICENSED",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@lumenize/testing": "^0.24.0",
    "@vitest/browser": "4.1.4",
    "@vitest/browser-playwright": "4.1.4",
    "@vitest/coverage-istanbul": "4.1.4",
    "playwright": "^1.48.2",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "4.1.4",
    "wrangler": "^4.72.0"
  },
  "dependencies": {
    "@lumenize/auth": "^0.24.0",
    "@lumenize/debug": "^0.24.0",
    "@lumenize/mesh": "^0.24.0",
    "@lumenize/nebula-auth": "^0.24.0",
    "@lumenize/routing": "^0.24.0",
    "@lumenize/structured-clone": "^0.24.0",
    "@lumenize/ts-runtime-parser-validator": "^0.24.0"
  },
  "peerDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "vitest": "4.1.4"
  }
}
